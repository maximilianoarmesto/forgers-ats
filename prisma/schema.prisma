// Prisma schema for Forgers ATS
// Note: Prisma models live in the infrastructure concern. Domain entities are
// mapped to/from these models inside src/infrastructure repositories.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleStatus {
  OPEN
  CLOSED
  ON_HOLD
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model Candidate {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  phone          String?
  stage          CandidateStage @default(APPLIED)
  jobTitle       String
  linkedinUrl    String?
  resumeKey      String?
  resumeFileName String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("candidates")
}

model Role {
  id             String     @id @default(uuid())
  title          String
  jobDescription String
  location       String
  company        String
  status         RoleStatus @default(OPEN)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("roles")
}
