# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://forgers:forgers@localhost:5432/forgers_ats?schema=public"

# Application
NODE_ENV="development"
PORT=3000

# Secret used to sign/verify the HS256 JWT access tokens that protect the API.
# Use a long, random value in production.
JWT_SECRET="dev-insecure-change-me"

# Directory where uploaded résumé PDFs are stored (local filesystem storage).
RESUME_STORAGE_DIR="./storage/resumes"
